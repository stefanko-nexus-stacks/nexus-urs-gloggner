# =============================================================================
# Nexus-Stack .gitignore
# =============================================================================

# OpenTofu / Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
.terraform.tfstate.lock.info
crash.log
crash.*.log

# Sensitive config files
# - config.tfvars: gitignored (generated by GitHub Actions)
# - services.yaml: committed (service definitions + image versions) - in project root
*.tfvars
*.tfvars.json

# Environment variables (secrets!)
.env

# R2 state backend (auto-generated by make init)
backend.hcl
.r2-credentials

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
*.swp
*.swo
*~
.idea/
.vscode/
.cursorrules
.cursor/
.claude/

# Logs
*.log

# Stack secrets (auto-generated on server)
stacks/.env
stacks/*/.env
# Infisical-managed secret block written by scripts/deploy.sh's
# secret-sync (currently only stacks/jupyter/.infisical.env, but
# the same pattern lands in code-server (#496) and marimo (#497)).
# Should never be in git — kept on the server only.
stacks/*/.infisical.env
*.infisical.env

# Generated firewall override files (created by deploy.sh)
stacks/*/docker-compose.firewall.yml

# Python (nexus_deploy package, see docs/admin-guides/migration-to-python.md)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
.hypothesis/
.venv/
dist/
build/
*.egg-info/
*.egg

# Phase-1 (#505) raw baseline captures from `scripts/capture-phase1-baselines.sh`.
# These contain unredacted Infisical secrets (passwords, tokens, encryption
# keys) and must never be committed. The Phase-1 module PRs will produce
# redacted, committable fixtures from these raw captures.
tests/fixtures/baselines/

# Control Plane (Astro)
control-plane/node_modules/
control-plane/dist/
control-plane/.astro/

# Wrangler CLI local cache (account id, pages config — should never be committed)
.wrangler/
