---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Settings" activeNav="settings" narrow={true}>
  <!-- Infrastructure Information -->
  <div class="panel">
    <h2>Infrastructure Information</h2>
    <div class="info-grid">
      <div class="info-item">
        <div class="info-item-label">Server Type</div>
        <div class="info-item-value" id="info-server-type">Loading...</div>
      </div>
      <div class="info-item">
        <div class="info-item-label">Location</div>
        <div class="info-item-value" id="info-server-location">Loading...</div>
      </div>
      <div class="info-item">
        <div class="info-item-label">Domain</div>
        <div class="info-item-value highlight" id="info-domain">Loading...</div>
      </div>
      <div class="info-item">
        <div class="info-item-label">Last Spin Up</div>
        <div class="info-item-value" id="info-last-deploy">Loading...</div>
      </div>
      <div class="info-item">
        <div class="info-item-label">Last Teardown</div>
        <div class="info-item-value" id="info-last-teardown">Loading...</div>
      </div>
      <div class="info-item">
        <div class="info-item-label">Uptime</div>
        <div class="info-item-value highlight" id="info-uptime">Loading...</div>
      </div>
    </div>
  </div>

  <!-- Scheduled Teardown -->
  <div class="panel">
    <h2>Scheduled Teardown</h2>
    <div class="setting-row">
      <div>
        <div class="setting-label">Automatic Daily Teardown</div>
        <div class="setting-info" id="scheduled-info">Loading...</div>
      </div>
      <div class="toggle-switch" id="toggle-scheduled-teardown"></div>
    </div>
    <button class="btn-warning" id="btn-delay-teardown" disabled style="margin-top: 0.8rem;">Delay Teardown</button>
  </div>

  <!-- Email Notifications -->
  <div class="panel">
    <h2>Email Notifications</h2>
    <div id="silent-mode-banner" class="silent-banner">
      Silent mode active — no automated emails will be sent. Enable a toggle below to disable silent mode.
    </div>
    <div class="setting-row">
      <div>
        <div class="setting-label">Shutdown Warning Email</div>
        <div class="setting-info">Sends an email before the scheduled daily teardown</div>
      </div>
      <div class="toggle-switch" id="toggle-notify-shutdown"></div>
    </div>
    <div class="setting-row">
      <div>
        <div class="setting-label">Stack Online Email</div>
        <div class="setting-info">Sends an email when the stack is back online after spin-up</div>
      </div>
      <div class="toggle-switch" id="toggle-notify-spinup"></div>
    </div>
  </div>

  <!-- Recent Workflows -->
  <div class="panel">
    <h2>Recent Workflows</h2>
    <div id="history-list">
      <p style="color: #607080; font-size: 0.8rem;">Loading...</p>
    </div>
  </div>
</Layout>

<style>
  .silent-banner {
    background: rgba(255, 180, 0, 0.08);
    border: 1px solid rgba(255, 180, 0, 0.3);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
    color: #ffb400;
    display: none;
  }

  .silent-banner.visible { display: block; }

  .history-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.8rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(0, 255, 136, 0.1);
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
  }

  .history-item .name { color: var(--text-secondary); }
  .history-item .status { font-weight: 700; }
  .history-item .status.success { color: var(--accent); }
  .history-item .status.failure { color: var(--error); }
  .history-item .status.in_progress { color: var(--warning); }
  .history-item a { color: var(--info); text-decoration: none; font-size: 0.75rem; }
  .history-item a:hover { text-decoration: underline; }
</style>

<script is:inline>
  const API_URL = '';

  async function fetchInfo() {
    try {
      const response = await fetch(API_URL + '/api/info', { credentials: 'same-origin' });
      const contentType = response.headers.get('content-type');
      if (!contentType || !contentType.includes('application/json')) return;
      const data = await response.json();
      if (!data.success) return;
      const info = data.info || {};

      document.getElementById('info-server-type').textContent = info.server?.type || 'Unknown';
      document.getElementById('info-server-location').textContent = info.server?.location || 'Unknown';
      document.getElementById('info-domain').textContent = info.server?.domain || 'Unknown';

      const lastSpinUp = info.server?.lastSpinUp || info.time?.lastDeploy;
      const lastTeardown = info.server?.lastTeardown || info.time?.lastTeardown;

      document.getElementById('info-last-deploy').textContent = lastSpinUp ? new Date(lastSpinUp).toLocaleString('de-CH') : 'Never';
      document.getElementById('info-last-teardown').textContent = lastTeardown ? new Date(lastTeardown).toLocaleString('de-CH') : 'Never';

      const elUptime = document.getElementById('info-uptime');
      if (info.time?.uptime) {
        const u = info.time.uptime;
        elUptime.textContent = u.days > 0 ? u.days + 'd ' + u.hours + 'h ' + u.minutes + 'm' : u.hours + 'h ' + u.minutes + 'm';
      } else if (lastSpinUp) {
        const diffMs = new Date() - new Date(lastSpinUp);
        elUptime.textContent = Math.floor(diffMs / 3600000) + 'h ' + Math.floor((diffMs % 3600000) / 60000) + 'm';
      } else {
        elUptime.textContent = 'N/A';
      }
    } catch (error) {
      console.error('Failed to fetch info:', error);
    }
  }

  async function loadScheduledTeardownConfig() {
    try {
      const response = await fetch(API_URL + '/api/scheduled-teardown', { credentials: 'same-origin' });
      const data = await response.json();
      if (!data.success || !data.config) return;
      const config = data.config;
      const toggle = document.getElementById('toggle-scheduled-teardown');
      const info = document.getElementById('scheduled-info');
      const delayBtn = document.getElementById('btn-delay-teardown');

      if (config.allowDisable === false) {
        toggle.classList.add('disabled');
        toggle.title = 'Auto-shutdown cannot be disabled (infrastructure policy)';
      } else {
        toggle.classList.remove('disabled');
        toggle.title = '';
      }

      const maxDelayHours = config.maxDelayHours || 4;
      const extensionsRemaining = config.extensionsRemaining !== undefined ? config.extensionsRemaining : null;
      const maxExtensions = config.maxExtensionsPerDay || 3;
      const limitReached = extensionsRemaining !== null && extensionsRemaining <= 0;

      // Update button label to reflect the configured max delay
      delayBtn.textContent = 'Delay Teardown by ' + maxDelayHours + ' Hours';

      // Escape values that originate from API/config before injecting into innerHTML
      const esc = (s) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

      // Append remaining-extensions counter when available (numbers, no escaping needed)
      const counterText = extensionsRemaining !== null
        ? '<br><span style="color: var(--text-muted); font-size: 0.85em;">' + extensionsRemaining + ' of ' + maxExtensions + ' daily extensions remaining</span>'
        : '';

      if (config.enabled) {
        toggle.classList.add('active');
        const now = new Date();
        const delayUntil = config.delayUntil ? new Date(config.delayUntil) : null;

        if (delayUntil && delayUntil > now) {
          const diffMs = delayUntil - now;
          const hours = Math.ceil(diffMs / 3600000);
          const minutes = Math.ceil((diffMs % 3600000) / 60000);
          info.innerHTML = 'Enabled - Teardown delayed until ' + esc(delayUntil.toLocaleString('de-CH')) + '<br><span style="color: var(--warning);">(' + hours + 'h ' + minutes + 'm remaining)</span>' + counterText;
          delayBtn.disabled = true;
        } else if (config.timeRemaining) {
          const tr = config.timeRemaining;
          let timeText = tr.hours > 0 ? tr.hours + 'h ' + tr.minutes + 'm' : tr.minutes + 'm';
          const next = config.nextTeardown ? esc(new Date(config.nextTeardown).toLocaleString('de-CH')) : '';
          info.innerHTML = 'Enabled - Next: ' + next + '<br><span style="color: var(--warning);">(' + timeText + ' remaining)</span>' + counterText;
          delayBtn.disabled = limitReached;
        } else {
          info.innerHTML = 'Enabled - Daily at ' + esc(config.teardownTime || '22:00') + ' ' + esc(config.timezone || 'UTC') + counterText;
          delayBtn.disabled = limitReached;
        }
      } else {
        toggle.classList.remove('active');
        info.textContent = 'Disabled - No automatic teardown';
        delayBtn.disabled = true;
      }

      toggle.onclick = function() {
        if (toggle.classList.contains('disabled')) return;
        saveScheduledTeardown(!toggle.classList.contains('active'));
      };
      delayBtn.onclick = function() { delayTeardown(); };
    } catch (error) {
      console.error('Failed to load scheduled teardown config:', error);
    }
  }

  async function saveScheduledTeardown(enabled) {
    try {
      const response = await fetch(API_URL + '/api/scheduled-teardown', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ enabled }),
      });
      const data = await response.json();
      if (data.success) {
        showToast('Scheduled teardown ' + (enabled ? 'enabled' : 'disabled'));
        loadScheduledTeardownConfig();
      } else {
        showToast(data.error || 'Failed to update', 'error');
      }
    } catch {
      showToast('Failed to update scheduled teardown', 'error');
    }
  }

  async function delayTeardown() {
    const btn = document.getElementById('btn-delay-teardown');
    const originalLabel = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Processing...';
    try {
      // Re-fetch current config to get the configured max delay hours
      const cfgResponse = await fetch(API_URL + '/api/scheduled-teardown', { credentials: 'same-origin' });
      const cfgData = await cfgResponse.json();
      const delayHours = (cfgData.success && cfgData.config && cfgData.config.maxDelayHours) || 4;

      const response = await fetch(API_URL + '/api/scheduled-teardown', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ delayHours }),
      });
      const data = await response.json();
      if (data.success) {
        showToast('Teardown delayed by ' + delayHours + ' hours');
        loadScheduledTeardownConfig();
      } else {
        showToast(data.error || 'Failed to delay', 'error');
        // Reload config so the counter, button label, and disabled state reflect
        // the current backend state (e.g. HTTP 429 means the daily limit was reached
        // and the button should remain disabled until UTC midnight).
        btn.textContent = originalLabel;
        loadScheduledTeardownConfig();
      }
    } catch {
      showToast('Failed to delay teardown', 'error');
      btn.textContent = originalLabel;
      loadScheduledTeardownConfig();
    }
  }

  async function loadEmailSettings() {
    try {
      const response = await fetch(API_URL + '/api/email-settings', { credentials: 'same-origin' });
      const data = await response.json();
      if (!data.success || !data.settings) return;
      const s = data.settings;
      const shutdownToggle = document.getElementById('toggle-notify-shutdown');
      const spinupToggle = document.getElementById('toggle-notify-spinup');
      const silentBanner = document.getElementById('silent-mode-banner');

      if (s.notifyOnShutdown) shutdownToggle.classList.add('active');
      else shutdownToggle.classList.remove('active');

      if (s.notifyOnSpinup) spinupToggle.classList.add('active');
      else spinupToggle.classList.remove('active');

      if (s.silentMode) silentBanner.classList.add('visible');
      else silentBanner.classList.remove('visible');

      shutdownToggle.onclick = function() { saveEmailSetting('notifyOnShutdown', !shutdownToggle.classList.contains('active')); };
      spinupToggle.onclick = function() { saveEmailSetting('notifyOnSpinup', !spinupToggle.classList.contains('active')); };
    } catch (error) {
      console.error('Failed to load email settings:', error);
    }
  }

  async function saveEmailSetting(key, value) {
    try {
      const body = {};
      body[key] = value;
      const response = await fetch(API_URL + '/api/email-settings', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await response.json();
      if (data.success) {
        showToast('Email setting updated');
        loadEmailSettings();
      } else {
        showToast(data.error || 'Failed to update', 'error');
      }
    } catch {
      showToast('Failed to update email setting', 'error');
    }
  }

  async function loadHistory() {
    try {
      const response = await fetch(API_URL + '/api/status', { credentials: 'same-origin' });
      const data = await response.json();
      if (!data.success) return;
      const historyList = document.getElementById('history-list');
      historyList.innerHTML = '';
      const workflows = data.workflows || {};
      const items = [
        { name: 'Spin Up', data: workflows.spinUp },
        { name: 'Teardown', data: workflows.teardown },
      ].filter(function(item) { return item.data; });

      if (items.length === 0) {
        historyList.innerHTML = '<p style="color: #607080; font-size: 0.8rem;">No recent workflows</p>';
        return;
      }

      items.forEach(function(item) {
        const div = document.createElement('div');
        div.className = 'history-item';
        const status = item.data.conclusion || item.data.status;
        const statusClass = status === 'success' ? 'success' : status === 'failure' ? 'failure' : status === 'in_progress' ? 'in_progress' : '';
        const time = item.data.updatedAt ? new Date(item.data.updatedAt).toLocaleString('de-CH') : '';
        const link = item.data.url ? '<a href="' + item.data.url + '" target="_blank" rel="noopener">View</a>' : '';
        div.innerHTML =
          '<span class="name">' + item.name + '</span>' +
          '<span class="status ' + statusClass + '">' + (status || 'unknown') + '</span>' +
          '<span style="color: #607080; font-size: 0.7rem;">' + time + '</span>' +
          link;
        historyList.appendChild(div);
      });
    } catch (error) {
      console.error('Failed to load history:', error);
    }
  }

  fetchInfo();
  loadScheduledTeardownConfig();
  loadEmailSettings();
  loadHistory();
</script>
