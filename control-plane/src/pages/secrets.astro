---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Secrets" activeNav="secrets" narrow={true}>
  <div class="secrets-intro">
    <p>Secrets are generated by OpenTofu and managed in <strong>Infisical</strong>. This is a read-only view.</p>
    <p class="hint">Hover to reveal &middot; Click to copy</p>
  </div>

  <div class="email-credentials-panel">
    <div class="email-credentials-text">
      <strong>Email Credentials</strong>
      <p>Sends an email with the <strong>Infisical admin URL, email, and password</strong> to the stack owner. All other service credentials live inside Infisical itself — log in there to view them.</p>
    </div>
    <button class="email-credentials-btn" id="btn-email-credentials">
      <span class="icon">&#x1F4E7;</span>
      <span class="label">Send Email</span>
    </button>
  </div>

  <div class="databricks-sync-panel">
    <div class="databricks-sync-text">
      <strong>Sync to Databricks</strong>
      <p>Mirrors every secret above into the Databricks <code>nexus</code> scope using keys like <code>postgres/POSTGRES_USERNAME</code>. Stale keys removed automatically. Configure the workspace host &amp; token under <a href="/integrations">Integrations</a> first.</p>
      <p class="databricks-last-sync" id="databricks-last-sync"></p>
    </div>
    <button class="databricks-sync-btn" id="btn-sync-databricks" disabled>
      <span class="icon">&#x21BB;</span>
      <span class="label">Sync Now</span>
    </button>
  </div>

  <div class="search-bar">
    <input type="text" id="secret-search" placeholder="Filter secrets..." autocomplete="off">
  </div>

  <div id="secrets-container">
    <div class="loading"><span class="spinner"></span> Loading secrets...</div>
  </div>
</Layout>

<style>
  .secrets-intro {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .secrets-intro strong {
    color: var(--accent);
  }

  .hint {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }

  /* Email Credentials panel (above the search bar) */
  .email-credentials-panel {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(168, 85, 247, 0.05);
    border: 1px solid rgba(168, 85, 247, 0.3);
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .email-credentials-text {
    flex: 1;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .email-credentials-text strong {
    color: #a855f7;
  }

  .email-credentials-text p {
    margin-top: 0.3rem;
  }

  .email-credentials-btn {
    flex-shrink: 0;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.5);
    color: #a855f7;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.7rem 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .email-credentials-btn:hover {
    background: rgba(168, 85, 247, 0.2);
    border-color: #a855f7;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .email-credentials-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  .email-credentials-btn .icon {
    font-size: 1.1rem;
  }

  /* Databricks Sync panel */
  .databricks-sync-panel {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(251, 146, 60, 0.05);
    border: 1px solid rgba(251, 146, 60, 0.3);
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .databricks-sync-text {
    flex: 1;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .databricks-sync-text strong {
    color: #fb923c;
  }

  .databricks-sync-text p {
    margin-top: 0.3rem;
  }

  .databricks-sync-text code {
    background: rgba(251, 146, 60, 0.12);
    border: 1px solid rgba(251, 146, 60, 0.25);
    padding: 0.05rem 0.35rem;
    border-radius: 2px;
    font-size: 0.78rem;
    color: #fbb980;
  }

  .databricks-sync-text a {
    color: #fb923c;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .databricks-last-sync {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .databricks-last-sync.status-success { color: #00ff88; }
  .databricks-last-sync.status-partial { color: #ffaa00; }
  .databricks-last-sync.status-failure { color: #ff6060; }

  .databricks-sync-btn {
    flex-shrink: 0;
    background: rgba(251, 146, 60, 0.1);
    border: 1px solid rgba(251, 146, 60, 0.5);
    color: #fb923c;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.7rem 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .databricks-sync-btn:hover:not(:disabled) {
    background: rgba(251, 146, 60, 0.2);
    border-color: #fb923c;
    box-shadow: 0 0 20px rgba(251, 146, 60, 0.3);
  }

  .databricks-sync-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .databricks-sync-btn .icon {
    font-size: 1.1rem;
  }

  .databricks-failed-details {
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .databricks-failed-details summary {
    cursor: pointer;
    color: #ff6060;
  }

  .databricks-failed-details ul {
    margin: 0.4rem 0 0 1rem;
    padding: 0;
    list-style: disc;
  }

  .databricks-failed-details li {
    margin-bottom: 0.2rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .databricks-warnings-details {
    margin-top: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .databricks-warnings-details summary {
    cursor: pointer;
    color: #ffaa00;
  }

  .databricks-warnings-details ul {
    margin: 0.4rem 0 0 1rem;
    padding: 0;
    list-style: disc;
  }

  .databricks-warnings-details li {
    margin-bottom: 0.2rem;
  }

  .search-bar {
    margin-bottom: 1.5rem;
  }

  .search-bar input {
    width: 100%;
    padding: 0.7rem 1rem;
    background: rgba(0, 10, 5, 0.8);
    border: 1px solid rgba(0, 255, 136, 0.2);
    color: #c0d0c0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    border-radius: 4px;
  }

  .search-bar input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 10px rgba(0, 255, 136, 0.1);
  }

  .search-bar input::placeholder { color: #607080; }

  /* Groups */
  :global(.secret-group) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    margin-bottom: 0.8rem;
    overflow: hidden;
  }

  :global(.secret-group.hidden) {
    display: none;
  }

  :global(.group-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 1.2rem;
    cursor: pointer;
    user-select: none;
    transition: background 0.2s;
  }

  :global(.group-header:hover) {
    background: rgba(0, 255, 136, 0.03);
  }

  :global(.group-name) {
    color: var(--accent);
    font-weight: 700;
    font-size: 0.9rem;
  }

  :global(.group-count) {
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  :global(.group-toggle) {
    color: var(--text-muted);
    font-size: 0.6rem;
    transition: transform 0.2s;
  }

  :global(.group-toggle.open) {
    transform: rotate(180deg);
  }

  :global(.group-body) {
    display: none;
    border-top: 1px solid var(--border);
  }

  :global(.group-body.open) {
    display: block;
  }

  /* Secret rows */
  :global(.secret-row) {
    display: flex;
    align-items: center;
    padding: 0.5rem 1.2rem;
    border-bottom: 1px solid rgba(42, 42, 62, 0.3);
    gap: 1rem;
    transition: background 0.15s;
  }

  :global(.secret-row:last-child) {
    border-bottom: none;
  }

  :global(.secret-row:hover) {
    background: rgba(0, 255, 136, 0.03);
  }

  :global(.secret-row.hidden) {
    display: none;
  }

  :global(.secret-key) {
    color: var(--text-secondary);
    font-size: 0.8rem;
    min-width: 200px;
    flex-shrink: 0;
  }

  :global(.secret-value) {
    flex: 1;
    font-size: 0.8rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.3rem 0.6rem;
    border: 1px solid transparent;
    border-radius: 3px;
    transition: all 0.2s;
    font-family: 'JetBrains Mono', monospace;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.secret-value:hover) {
    color: var(--text-primary);
    border-color: rgba(0, 255, 136, 0.2);
    background: rgba(0, 255, 136, 0.05);
  }

  :global(.secret-value .masked) {
    letter-spacing: 0.15em;
  }

  :global(.secret-value .revealed) {
    display: none;
  }

  :global(.secret-value:hover .masked) {
    display: none;
  }

  :global(.secret-value:hover .revealed) {
    display: inline;
    color: var(--accent);
  }

  :global(.secret-value.copied) {
    border-color: var(--accent);
    background: rgba(0, 255, 136, 0.1);
  }

  :global(.no-secrets) {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>

<script is:inline>
  function escapeAttr(str) {
    return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  async function loadSecrets() {
    const container = document.getElementById('secrets-container');
    try {
      const res = await fetch('/api/secrets', { credentials: 'same-origin' });
      const contentType = res.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) {
        container.innerHTML = '<div class="no-secrets">The secrets API returned an unexpected response. This usually means the API endpoint is not deployed correctly or Cloudflare Access is blocking the request. Try running Spin Up again.</div>';
        console.error('Secrets API returned non-JSON:', res.status, contentType);
        return;
      }
      const data = await res.json();

      if (!data.success) {
        container.innerHTML = '<div class="no-secrets">Error: ' + escapeHtml(data.error) + '</div>';
        return;
      }

      if (!data.groups || data.groups.length === 0) {
        container.innerHTML = '<div class="no-secrets">' + escapeHtml(data.message || 'No secrets available. Run Spin Up to generate secrets.') + '</div>';
        return;
      }

      container.innerHTML = '';

      data.groups.forEach(function(group) {
        var groupEl = document.createElement('div');
        groupEl.className = 'secret-group';
        groupEl.dataset.groupName = group.name.toLowerCase();

        var headerHtml = '<div class="group-header" onclick="toggleGroup(this)">' +
          '<div><span class="group-name">' + escapeHtml(group.name) + '</span> ' +
          '<span class="group-count">' + group.secrets.length + '</span></div>' +
          '<span class="group-toggle">&#9660;</span>' +
          '</div>';

        var bodyHtml = '<div class="group-body">';
        group.secrets.forEach(function(secret) {
          bodyHtml += '<div class="secret-row" data-key="' + escapeAttr(secret.key.toLowerCase()) + '">' +
            '<span class="secret-key">' + escapeHtml(secret.key) + '</span>' +
            '<span class="secret-value" onclick="copySecret(this)" data-value="' + escapeAttr(secret.value) + '">' +
              '<span class="masked">••••••••••••</span>' +
              '<span class="revealed">' + escapeHtml(secret.value) + '</span>' +
            '</span>' +
            '</div>';
        });
        bodyHtml += '</div>';

        groupEl.innerHTML = headerHtml + bodyHtml;
        container.appendChild(groupEl);
      });
    } catch (error) {
      container.innerHTML = '<div class="no-secrets">Failed to load secrets.</div>';
      console.error('Failed to load secrets:', error);
    }
  }

  function toggleGroup(header) {
    var body = header.nextElementSibling;
    var icon = header.querySelector('.group-toggle');
    body.classList.toggle('open');
    icon.classList.toggle('open');
  }

  function copySecret(el) {
    var value = el.dataset.value;
    navigator.clipboard.writeText(value).then(function() {
      el.classList.add('copied');
      showToast('Copied to clipboard');
      setTimeout(function() { el.classList.remove('copied'); }, 1500);
    }).catch(function() {
      showToast('Failed to copy', 'error');
    });
  }

  // Search/filter
  var searchTimeout;
  document.getElementById('secret-search').addEventListener('input', function(e) {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(function() {
      var q = e.target.value.toLowerCase();
      var groups = document.querySelectorAll('.secret-group');

      groups.forEach(function(group) {
        var rows = group.querySelectorAll('.secret-row');
        var anyVisible = false;

        rows.forEach(function(row) {
          var key = row.dataset.key;
          var match = !q || key.includes(q) || group.dataset.groupName.includes(q);
          row.classList.toggle('hidden', !match);
          if (match) anyVisible = true;
        });

        group.classList.toggle('hidden', !anyVisible);

        // Auto-open groups with matches when searching
        if (q && anyVisible) {
          group.querySelector('.group-body').classList.add('open');
          group.querySelector('.group-toggle').classList.add('open');
        }
      });
    }, 150);
  });

  loadSecrets();

  // Email Credentials button — POST /api/send-credentials.
  // Mirrors the content-type handling used in loadSecrets() above so a
  // non-JSON response (Cloudflare Access HTML login page, proxy error,
  // etc.) surfaces an actionable "session expired" toast instead of
  // being swallowed by the generic catch.
  async function emailCredentials() {
    const btn = document.getElementById('btn-email-credentials');
    if (!btn) return;
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span><span class="label">Sending&hellip;</span>';
    try {
      const response = await fetch('/api/send-credentials', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' }
      });
      const ct = response.headers.get('content-type') || '';
      if (!ct.includes('application/json')) {
        showToast('Session expired — please refresh the page', 'error');
        return;
      }
      const data = await response.json();
      showToast(
        data.success ? 'Credentials email sent!' : (data.error || 'Failed to send email'),
        data.success ? 'success' : 'error'
      );
    } catch (e) {
      showToast('Failed to send email', 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalHTML;
    }
  }

  const emailBtn = document.getElementById('btn-email-credentials');
  if (emailBtn) emailBtn.addEventListener('click', emailCredentials);

  // Databricks sync panel: configuration check, last-sync summary, trigger.
  // Same content-type guard as loadSecrets() so a Cloudflare Access logout
  // page surfaces as "session expired" instead of a generic failure.
  const dbxBtn = document.getElementById('btn-sync-databricks');
  const dbxLast = document.getElementById('databricks-last-sync');

  function formatLastSync(data) {
    // Gate on `status` not `success` — POST returns success:false for any run
    // with failed keys, but those runs still have timestamp/upserted/deleted/
    // failed fields that the user needs to see.
    if (!data || !data.status) return '';
    if (data.status === 'never') return 'Not synced yet.';
    const when = data.timestamp ? data.timestamp.replace('T', ' ').replace(/\..*$/, '') + ' UTC' : '';
    const parts = [];
    if (typeof data.upserted === 'number') parts.push(data.upserted + ' synced');
    if (typeof data.deleted === 'number' && data.deleted > 0) parts.push(data.deleted + ' removed');
    if (Array.isArray(data.failed) && data.failed.length > 0) parts.push(data.failed.length + ' failed');
    const summary = parts.length ? parts.join(' · ') : (data.message || '');
    return 'Last sync: ' + (when || 'unknown') + (summary ? ' — ' + summary : '');
  }

  function renderLastSync(data) {
    if (!dbxLast) return;
    dbxLast.classList.remove('status-success', 'status-partial', 'status-failure');
    if (data && data.status === 'success') dbxLast.classList.add('status-success');
    else if (data && data.status === 'partial') dbxLast.classList.add('status-partial');
    else if (data && data.status === 'failure') dbxLast.classList.add('status-failure');
    dbxLast.textContent = formatLastSync(data);

    // Wipe and re-render the auxiliary blocks (failures + warnings) so they
    // can't stack across consecutive syncs.
    document.querySelectorAll('.databricks-failed-details, .databricks-warnings-details').forEach(function(el) { el.remove(); });

    if (data && Array.isArray(data.failed) && data.failed.length > 0) {
      const details = document.createElement('details');
      details.className = 'databricks-failed-details';
      let html = '<summary>' + data.failed.length + ' key(s) failed — click to expand</summary><ul>';
      data.failed.forEach(function(f) {
        html += '<li>' + escapeHtml(f.key) + ': ' + escapeHtml(f.error || 'unknown') + '</li>';
      });
      html += '</ul>';
      details.innerHTML = html;
      dbxLast.parentElement.appendChild(details);
    }

    // Warnings — drift-cleanup skipped, Infisical folder fetch errors, etc.
    // Rendered as a separate block so they don't get buried under the failed
    // keys and so the colour can signal "caveat" rather than "hard failure".
    if (data && Array.isArray(data.warnings) && data.warnings.length > 0) {
      const details = document.createElement('details');
      details.className = 'databricks-warnings-details';
      let html = '<summary>' + data.warnings.length + ' warning(s) — click to expand</summary><ul>';
      data.warnings.forEach(function(w) {
        html += '<li>' + escapeHtml(w) + '</li>';
      });
      html += '</ul>';
      details.innerHTML = html;
      dbxLast.parentElement.appendChild(details);
    }
  }

  async function refreshDatabricksConfig() {
    // Button-enabled gate only — does NOT touch the last-sync rendering.
    // Called from the POST finally-block so a slow/failed GET can't overwrite
    // the fresh result we already rendered from the POST response.
    if (!dbxBtn) return;
    try {
      const cfgRes = await fetch('/api/databricks-config', { credentials: 'same-origin' });
      const ct = cfgRes.headers.get('content-type') || '';
      if (ct.includes('application/json')) {
        const cfg = await cfgRes.json();
        dbxBtn.disabled = !(cfg.success && cfg.configured);
        dbxBtn.title = cfg.configured ? '' : 'Configure Databricks host and token under Integrations first';
      }
    } catch {
      dbxBtn.disabled = true;
    }
  }

  async function refreshDatabricksPanel() {
    // Initial-load path: fetch config state AND the persisted last-sync
    // summary. Only called on mount — post-sync refreshes must use
    // refreshDatabricksConfig() alone so the rendering is preserved.
    if (!dbxBtn) return;
    await refreshDatabricksConfig();
    try {
      const res = await fetch('/api/databricks-sync', { credentials: 'same-origin' });
      const ct = res.headers.get('content-type') || '';
      if (!ct.includes('application/json')) return;
      renderLastSync(await res.json());
    } catch { /* leave panel empty on transient error */ }
  }

  async function syncDatabricks() {
    if (!dbxBtn) return;
    const originalHTML = dbxBtn.innerHTML;
    dbxBtn.disabled = true;
    dbxBtn.innerHTML = '<span class="spinner"></span><span class="label">Syncing&hellip;</span>';
    try {
      const res = await fetch('/api/databricks-sync', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
      });
      const ct = res.headers.get('content-type') || '';
      if (!ct.includes('application/json')) {
        showToast('Session expired — please refresh the page', 'error');
        return;
      }
      const data = await res.json();
      renderLastSync(data);
      const toastType = data.success ? 'success' : 'error';
      const toastMsg = data.message || (data.success ? 'Sync complete' : (data.error || 'Sync failed'));
      showToast(toastMsg, toastType);
    } catch (e) {
      showToast('Failed to trigger sync', 'error');
    } finally {
      dbxBtn.innerHTML = originalHTML;
      // Re-check config only — the last-sync rendering was just produced from
      // the POST response and is authoritative; a GET re-fetch here could race
      // with KV propagation or a transient error and overwrite the truth.
      refreshDatabricksConfig();
    }
  }

  if (dbxBtn) {
    dbxBtn.addEventListener('click', syncDatabricks);
    refreshDatabricksPanel();
  }
</script>
