---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Integrations" activeNav="integrations" narrow={true}>
  <!-- Databricks Integration -->
  <div class="integration-panel">
    <h2>Databricks Integration</h2>
    <p>Connect your Nexus Stack to a Databricks workspace. Once configured, every Infisical secret can be mirrored into the Databricks <code>nexus</code> secret scope so notebooks can read credentials with <code>dbutils.secrets.get()</code>.</p>
    <div class="form-group">
      <label>Workspace URL</label>
      <input type="text" id="databricks-host" placeholder="https://dbc-xxxxx.cloud.databricks.com">
    </div>
    <div class="form-group">
      <label>Personal Access Token</label>
      <input type="password" id="databricks-token" placeholder="dapi...">
    </div>
    <div class="btn-row">
      <button class="btn-primary" id="btn-save-databricks" onclick="saveDatabricksConfig()">Save Configuration</button>
    </div>
    <div id="databricks-status" class="status-text"></div>
  </div>

  <!-- Databricks Sync (moved from Secrets tab — belongs next to its configuration) -->
  <div class="databricks-sync-panel">
    <div class="databricks-sync-text">
      <strong>Sync to Databricks</strong>
      <p>Mirrors every secret from the <a href="/secrets">Secrets page</a> into the Databricks <code>nexus</code> scope using keys like <code>postgres/POSTGRES_USERNAME</code>. Stale keys removed automatically. Configure the workspace host &amp; token above first.</p>
      <p class="databricks-last-sync" id="databricks-last-sync"></p>
    </div>
    <button class="databricks-sync-btn" id="btn-sync-databricks" disabled>
      <span class="icon">&#x21BB;</span>
      <span class="label">Sync Now</span>
    </button>
  </div>

  <div class="coming-soon">More integrations coming soon</div>
</Layout>

<style>
  .integration-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .integration-panel h2 {
    color: var(--accent);
    font-size: 1.1rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .integration-panel p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 1.2rem;
  }

  .integration-panel code {
    background: rgba(0, 255, 136, 0.08);
    border: 1px solid rgba(0, 255, 136, 0.2);
    padding: 0.05rem 0.35rem;
    border-radius: 2px;
    font-size: 0.78rem;
    color: var(--accent);
  }

  .form-group { margin-bottom: 1rem; }

  .btn-row {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .btn-row .btn-primary { flex: 1; }

  .status-text {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.8rem;
  }

  /* Databricks Sync panel (moved from Secrets tab) */
  .databricks-sync-panel {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(251, 146, 60, 0.05);
    border: 1px solid rgba(251, 146, 60, 0.3);
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .databricks-sync-text {
    flex: 1;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .databricks-sync-text strong {
    color: #fb923c;
  }

  .databricks-sync-text p {
    margin-top: 0.3rem;
  }

  .databricks-sync-text code {
    background: rgba(251, 146, 60, 0.12);
    border: 1px solid rgba(251, 146, 60, 0.25);
    padding: 0.05rem 0.35rem;
    border-radius: 2px;
    font-size: 0.78rem;
    color: #fbb980;
  }

  .databricks-sync-text a {
    color: #fb923c;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .databricks-last-sync {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .databricks-last-sync.status-success { color: #00ff88; }
  .databricks-last-sync.status-partial { color: #ffaa00; }
  .databricks-last-sync.status-failure { color: #ff6060; }

  .databricks-sync-btn {
    flex-shrink: 0;
    background: rgba(251, 146, 60, 0.1);
    border: 1px solid rgba(251, 146, 60, 0.5);
    color: #fb923c;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.7rem 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .databricks-sync-btn:hover:not(:disabled) {
    background: rgba(251, 146, 60, 0.2);
    border-color: #fb923c;
    box-shadow: 0 0 20px rgba(251, 146, 60, 0.3);
  }

  .databricks-sync-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .databricks-sync-btn .icon {
    font-size: 1.1rem;
  }

  .databricks-failed-details {
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .databricks-failed-details summary {
    cursor: pointer;
    color: #ff6060;
  }

  .databricks-failed-details ul {
    margin: 0.4rem 0 0 1rem;
    padding: 0;
    list-style: disc;
  }

  .databricks-failed-details li {
    margin-bottom: 0.2rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .databricks-warnings-details {
    margin-top: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .databricks-warnings-details summary {
    cursor: pointer;
    color: #ffaa00;
  }

  .databricks-warnings-details ul {
    margin: 0.4rem 0 0 1rem;
    padding: 0;
    list-style: disc;
  }

  .databricks-warnings-details li {
    margin-bottom: 0.2rem;
  }

  .coming-soon {
    color: var(--text-muted);
    font-size: 0.85rem;
    text-align: center;
    padding: 2rem;
    border: 1px dashed var(--border);
    margin-top: 1.5rem;
  }
</style>

<script is:inline>
  // Single initial config GET on mount: populates the form + status
  // text AND toggles the Sync button. refreshDatabricksConfig() takes
  // over after saveDatabricksConfig() to re-check when the operator
  // changes credentials mid-page. (Previously this function and
  // refreshDatabricksPanel() each fetched /api/databricks-config on
  // load — two requests for the same data; consolidated to one.)
  async function loadDatabricksConfig() {
    try {
      const res = await fetch('/api/databricks-config');
      const data = await res.json();
      if (data.success) {
        document.getElementById('databricks-host').value = data.host || '';
        if (data.configured) {
          document.getElementById('databricks-status').textContent = 'Configured';
          document.getElementById('databricks-status').style.color = '#00ff88';
        }
        // Sync-button gate. ``dbxBtn`` is bound below in this same
        // <script> block; this function runs after that binding is
        // hoisted at parse time.
        const btn = document.getElementById('btn-sync-databricks');
        if (btn) {
          btn.disabled = !data.configured;
          btn.title = data.configured ? '' : 'Configure Databricks host and token above first';
        }
      }
    } catch (error) {
      console.error('Failed to load Databricks configuration:', error);
      const statusEl = document.getElementById('databricks-status');
      if (statusEl) {
        statusEl.textContent = 'Failed to load configuration';
        statusEl.style.color = '#ff6060';
      }
    }
  }

  async function saveDatabricksConfig() {
    const host = document.getElementById('databricks-host').value.trim();
    const token = document.getElementById('databricks-token').value.trim();
    const status = document.getElementById('databricks-status');

    if (!host || !token) {
      status.textContent = 'Both fields are required';
      status.style.color = '#ff6060';
      return;
    }

    try {
      status.textContent = 'Saving...';
      status.style.color = '#ffaa00';
      const res = await fetch('/api/databricks-config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ host, token }),
      });
      const data = await res.json();
      if (data.success) {
        status.textContent = 'Configuration saved';
        status.style.color = '#00ff88';
        document.getElementById('databricks-token').value = '';
        // Re-check the sync panel — button enables now that config
        // is valid, without requiring a page reload.
        refreshDatabricksConfig();
      } else {
        status.textContent = data.error || 'Failed to save';
        status.style.color = '#ff6060';
      }
    } catch {
      status.textContent = 'Failed to save configuration';
      status.style.color = '#ff6060';
    }
  }

  loadDatabricksConfig();

  // ---------------------------------------------------------------
  // Databricks Sync panel — moved from Secrets tab. saveDatabricksConfig()
  // calls refreshDatabricksConfig() so the Sync button enables
  // immediately after the host+token have been persisted, no reload
  // needed.
  // ---------------------------------------------------------------
  function escapeHtml(str) {
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  const dbxBtn = document.getElementById('btn-sync-databricks');
  const dbxLast = document.getElementById('databricks-last-sync');

  function formatLastSync(data) {
    // Gate on `status` not `success` — POST returns success:false for any run
    // with failed keys, but those runs still have timestamp/upserted/deleted/
    // failed fields that the user needs to see.
    if (!data || !data.status) return '';
    if (data.status === 'never') return 'Not synced yet.';
    const when = data.timestamp ? data.timestamp.replace('T', ' ').replace(/\..*$/, '') + ' UTC' : '';
    const parts = [];
    if (typeof data.upserted === 'number') parts.push(data.upserted + ' synced');
    if (typeof data.deleted === 'number' && data.deleted > 0) parts.push(data.deleted + ' removed');
    if (Array.isArray(data.failed) && data.failed.length > 0) parts.push(data.failed.length + ' failed');
    const summary = parts.length ? parts.join(' · ') : (data.message || '');
    return 'Last sync: ' + (when || 'unknown') + (summary ? ' — ' + summary : '');
  }

  function renderLastSync(data) {
    if (!dbxLast) return;
    dbxLast.classList.remove('status-success', 'status-partial', 'status-failure');
    if (data && data.status === 'success') dbxLast.classList.add('status-success');
    else if (data && data.status === 'partial') dbxLast.classList.add('status-partial');
    else if (data && data.status === 'failure') dbxLast.classList.add('status-failure');
    dbxLast.textContent = formatLastSync(data);

    // Wipe and re-render the auxiliary blocks (failures + warnings) so they
    // can't stack across consecutive syncs.
    document.querySelectorAll('.databricks-failed-details, .databricks-warnings-details').forEach(function(el) { el.remove(); });

    if (data && Array.isArray(data.failed) && data.failed.length > 0) {
      const details = document.createElement('details');
      details.className = 'databricks-failed-details';
      let html = '<summary>' + data.failed.length + ' key(s) failed — click to expand</summary><ul>';
      data.failed.forEach(function(f) {
        html += '<li>' + escapeHtml(f.key) + ': ' + escapeHtml(f.error || 'unknown') + '</li>';
      });
      html += '</ul>';
      details.innerHTML = html;
      dbxLast.parentElement.appendChild(details);
    }

    if (data && Array.isArray(data.warnings) && data.warnings.length > 0) {
      const details = document.createElement('details');
      details.className = 'databricks-warnings-details';
      let html = '<summary>' + data.warnings.length + ' warning(s) — click to expand</summary><ul>';
      data.warnings.forEach(function(w) {
        html += '<li>' + escapeHtml(w) + '</li>';
      });
      html += '</ul>';
      details.innerHTML = html;
      dbxLast.parentElement.appendChild(details);
    }
  }

  async function refreshDatabricksConfig() {
    if (!dbxBtn) return;
    try {
      const cfgRes = await fetch('/api/databricks-config', { credentials: 'same-origin' });
      const ct = cfgRes.headers.get('content-type') || '';
      if (ct.includes('application/json')) {
        const cfg = await cfgRes.json();
        dbxBtn.disabled = !(cfg.success && cfg.configured);
        dbxBtn.title = cfg.configured ? '' : 'Configure Databricks host and token above first';
      }
    } catch {
      dbxBtn.disabled = true;
    }
  }

  // Initial load helper — only fetches the last-sync summary.
  // The config-GET / button-gate is handled by loadDatabricksConfig()
  // (called separately above) so we don't double-fetch on mount.
  async function loadLastSync() {
    if (!dbxBtn) return;
    try {
      const res = await fetch('/api/databricks-sync', { credentials: 'same-origin' });
      const ct = res.headers.get('content-type') || '';
      if (!ct.includes('application/json')) return;
      renderLastSync(await res.json());
    } catch { /* leave panel empty on transient error */ }
  }

  async function syncDatabricks() {
    if (!dbxBtn) return;
    const originalHTML = dbxBtn.innerHTML;
    dbxBtn.disabled = true;
    dbxBtn.innerHTML = '<span class="spinner"></span><span class="label">Syncing&hellip;</span>';
    try {
      const res = await fetch('/api/databricks-sync', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
      });
      const ct = res.headers.get('content-type') || '';
      if (!ct.includes('application/json')) {
        if (typeof showToast === 'function') showToast('Session expired — please refresh the page', 'error');
        return;
      }
      const data = await res.json();
      renderLastSync(data);
      if (typeof showToast === 'function') {
        const toastType = data.success ? 'success' : 'error';
        const toastMsg = data.message || (data.success ? 'Sync complete' : (data.error || 'Sync failed'));
        showToast(toastMsg, toastType);
      }
    } catch (e) {
      if (typeof showToast === 'function') showToast('Failed to trigger sync', 'error');
    } finally {
      dbxBtn.innerHTML = originalHTML;
      refreshDatabricksConfig();
    }
  }

  if (dbxBtn) {
    dbxBtn.addEventListener('click', syncDatabricks);
    loadLastSync();
  }
</script>
