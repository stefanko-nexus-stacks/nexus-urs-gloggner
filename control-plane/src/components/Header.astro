---
interface Props {
  activeNav?: string;
}

const { activeNav = '' } = Astro.props;

const navItems = [
  { href: '/', label: 'Dashboard', id: 'dashboard' },
  { href: '/stacks', label: 'Stacks', id: 'stacks' },
  { href: '/monitoring', label: 'Monitoring', id: 'monitoring' },
  { href: '/secrets', label: 'Secrets', id: 'secrets' },
  { href: '/firewall', label: 'Firewall', id: 'firewall' },
  { href: '/settings', label: 'Settings', id: 'settings' },
  { href: '/integrations', label: 'Integrations', id: 'integrations' },
];
---

<header>
  <img src="/nexus-logo-green.png" alt="Nexus Stack" class="logo">
  <h1>NEXUS STACK</h1>
  <p class="tagline">Control Panel &middot; <span id="version-tag" class="version-tag"></span></p>
  <nav class="nav-links">
    {navItems.map(item => (
      <a href={item.href} class={activeNav === item.id ? 'active' : ''}>
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  async function fetchVersion() {
    try {
      const r = await fetch('/api/version', { credentials: 'same-origin' });
      if (r.ok) {
        const d = await r.json();
        const t = document.getElementById('version-tag');
        if (t && d.version) t.textContent = d.version;
      }
    } catch {}
  }
  fetchVersion();
</script>

<style>
  header {
    text-align: center;
    border-bottom: none;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
  }

  .logo {
    display: block;
    width: 360px;
    max-width: 100%;
    height: auto;
    margin: 0 auto 1.5rem;
    filter: drop-shadow(0 0 20px rgba(0, 255, 136, 0.5));
  }

  h1 {
    color: var(--accent);
    font-family: 'Orbitron', sans-serif;
    font-size: 2.5rem;
    text-shadow: 0 0 10px rgba(0, 255, 136, 0.8), 0 0 40px rgba(0, 255, 136, 0.4);
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 0.85rem;
    color: #00ff88;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    opacity: 0.7;
  }

  .version-tag {
    font-size: 0.75rem;
    color: #00ff88;
    opacity: 0.5;
    letter-spacing: 0.1em;
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: all 0.3s;
  }

  .nav-links a:hover {
    color: var(--text-secondary);
    border-color: var(--text-muted);
  }

  .nav-links a.active {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(0, 255, 136, 0.08);
  }
</style>
